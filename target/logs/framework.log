if ( ww > 85) {
$('#hdv3Product3FooterBarrID').addClass('hiddenAtLoad');
} else if ( ww <= 85) {
$('#hdv3Product3FooterBarrID').removeClass('hiddenAtLoad');
}
} else {
$('#hdv3Product3FooterBarrID').removeClass('hiddenAtLoad');
}
});
</script>
